      "source": [
        "def encode_numeric_zscore(df, name, mean=None, sd=None):\n",
        "    if mean is None:\n",
        "        mean = df[name].mean()\n",
        "\n",
        "    if sd is None:\n",
        "        sd = df[name].std()\n",
        "\n",
        "    df[name] = (df[name] - mean) / sd\n",
        "\n",
        "# Encode text values to dummy variables(i.e. [1,0,0],\n",
        "# [0,1,0],[0,0,1] for red,green,blue)\n",
        "def encode_text_dummy(df, name):\n",
        "\t\t  dummies = pd.get_dummies(df[name])\n",
        "\t\t  for x in dummies.columns:\n",
        "\t\t      dummy_name = str(name)+ \"-\" +str(x)\n",
        "\t\t      df[dummy_name] = dummies[x]\n",
        "\t\t  df.drop(name, axis=1, inplace=True)\n",
        "encode_numeric_zscore(kf, 'duration')\n",
        "encode_numeric_zscore(kf, 'src_bytes')\n",
        "encode_numeric_zscore(kf, 'dst_bytes')\n",
        "encode_numeric_zscore(kf, 'land')\n",
        "encode_numeric_zscore(kf, 'wrong_fragment')\n",
        "encode_numeric_zscore(kf, 'urgent')\n",
        "encode_numeric_zscore(kf, 'hot')\n",
        "encode_numeric_zscore(kf, 'num_failed_logins')\n",
        "encode_numeric_zscore(kf, 'logged_in')\n",
        "encode_numeric_zscore(kf, 'num_compromised')\n",
        "encode_numeric_zscore(kf, 'root_shell')\n",
        "encode_numeric_zscore(kf, 'su_attempted')\n",
        "encode_numeric_zscore(kf, 'num_root')\n",
        "encode_numeric_zscore(kf, 'num_file_creations')\n",
        "encode_numeric_zscore(kf, 'num_shells')\n",
        "encode_numeric_zscore(kf, 'num_access_files')\n",
        "encode_numeric_zscore(kf, 'num_outbound_cmds')\n",
        "encode_numeric_zscore(kf, 'is_host_login')\n",
        "encode_numeric_zscore(kf, 'is_guest_login')\n",
        "encode_numeric_zscore(kf, 'count')\n",
        "encode_numeric_zscore(kf, 'srv_count')\n",
        "encode_numeric_zscore(kf, 'serror_rate')\n",
        "encode_numeric_zscore(kf, 'srv_serror_rate')\n",
        "encode_numeric_zscore(kf, 'rerror_rate')\n",
        "encode_numeric_zscore(kf, 'srv_rerror_rate')\n",
        "encode_numeric_zscore(kf, 'same_srv_rate')\n",
        "encode_numeric_zscore(kf, 'diff_srv_rate')\n",
        "encode_numeric_zscore(kf, 'srv_diff_host_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_count')\n",
        "encode_numeric_zscore(kf, 'dst_host_srv_count')\n",
        "encode_numeric_zscore(kf, 'dst_host_same_srv_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_diff_srv_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_same_src_port_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_srv_diff_host_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_serror_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_srv_serror_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_rerror_rate')\n",
        "encode_numeric_zscore(kf, 'dst_host_srv_rerror_rate')\n",
        "df.dropna(inplace=True,axis=1)\n",
        "\n"
